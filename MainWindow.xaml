<Window
    x:Class="SnakeGame.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SnakeGame"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="window"
    Title="Змейка"
    Width="800"
    Height="450"
    MinWidth="400"
    MinHeight="300"
    Background="#3c3"
    Icon="icon.ico"
    PreviewKeyDown="Window_PreviewKeyDown"
    Style="{StaticResource WindowStyle}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            Grid.Column="1"
            Margin="5,7,5,5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#2fff">
            <Rectangle
                Width="3"
                Margin="-3,-1"
                HorizontalAlignment="Left">
                <Rectangle.Fill>
                    <LinearGradientBrush EndPoint="1,0">
                        <GradientStop Offset="0" Color="#0000" />
                        <GradientStop Offset="1" Color="#2fff" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle
                Width="3"
                Margin="-3,-1"
                HorizontalAlignment="Right">
                <Rectangle.Fill>
                    <LinearGradientBrush EndPoint="1,0">
                        <GradientStop Offset="0" Color="#2fff" />
                        <GradientStop Offset="1" Color="#0000" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle
                Height="3"
                Margin="-1,-3"
                VerticalAlignment="Top">
                <Rectangle.Fill>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Offset="0" Color="#0000" />
                        <GradientStop Offset="1" Color="#2fff" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Rectangle
                Height="3"
                Margin="-1,-3"
                VerticalAlignment="Bottom">
                <Rectangle.Fill>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Offset="0" Color="#2fff" />
                        <GradientStop Offset="1" Color="#0000" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Viewbox>
                <Grid Width="{Binding ElementName=MainFrame, Path=Width}" Height="{Binding ElementName=MainFrame, Path=Height}">
                    <Grid.Background>
                        <VisualBrush
                            Stretch="UniformToFill"
                            TileMode="Tile"
                            ViewboxUnits="RelativeToBoundingBox"
                            ViewportUnits="Absolute">
                            <VisualBrush.Transform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="2" ScaleY="2" />
                                </TransformGroup>
                            </VisualBrush.Transform>
                            <VisualBrush.Visual>
                                <Image
                                    Opacity="0.02"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    Source="/Images/checker.bmp"
                                    Stretch="None" />
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Grid.Background>
                </Grid>
            </Viewbox>
            <Viewbox>
                <Viewbox>
                    <Viewbox.Effect>
                        <DropShadowEffect
                            BlurRadius="0"
                            Direction="270"
                            ShadowDepth="0.02" />
                    </Viewbox.Effect>
                    <Grid
                        x:Name="MainFrame"
                        Width="11"
                        Height="11" />
                </Viewbox>
            </Viewbox>
        </Grid>
        <Rectangle Fill="#2444" />
        <Label
            Margin="3,5"
            VerticalAlignment="Bottom"
            HorizontalContentAlignment="Left"
            Background="Transparent"
            Content="Автор: &#10;Воронин Даниил"
            Opacity="0.5">
            <Label.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Direction="270"
                    Opacity="0.5"
                    ShadowDepth="2" />
            </Label.Effect>
        </Label>
